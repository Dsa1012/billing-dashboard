# ── Carpeta Excel (solo modo LOCAL, no se usa en Railway) ────
EXCEL_FOLDER=C:/Users/user/OneDrive - actsa.net/00 Control de Gestión/Pipeline/2026

# ── Estructura del Excel ─────────────────────────────────────
DATA_START_ROW=3
YEAR_START_COL=61
YEAR_END_COL=74
COLOR_TOLERANCE=25

# ── Servidor ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*
WATCH_INTERVAL=60

# ── MODO NUBE — Supabase Storage ─────────────────────────────
# Completa estas variables para activar el modo nube.
# Obtén los valores desde: supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=tu_anon_public_key_aqui
SUPABASE_BUCKET=dashboard-data
SUPABASE_FILE=pipeline.xlsx
